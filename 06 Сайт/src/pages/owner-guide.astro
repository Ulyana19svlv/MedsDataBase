---
import AppLayout from "../layouts/AppLayout.astro";
import { dashboard } from "../lib/ui";

type DataIssue = {
  severity: string;
  message: string;
};

const issues = dashboard.issues as DataIssue[];
---

<AppLayout title="Процесс базы · Медицинская база">
  <section class="page-header">
    <p class="eyebrow">Служебное</p>
    <h1>Процесс новых анализов</h1>
    <p>Вы добавляете исходники, я разбираю их, обновляю события, показатели и сайт. Терминал вам трогать не нужно.</p>
  </section>

  <section class="detail-grid">
    <article class="card prose">
      <h2>Как добавлять новые анализы</h2>
      <ol>
        <li>Положить PDF, фото или скан в папку `04 Входящие/00 Новые файлы`.</li>
        <li>Написать мне: “обработай новые анализы”.</li>
        <li>Я создам событие в нужной папке человека, сохраню исходник, извлеку показатели и подготовлю проверку.</li>
        <li>В Obsidian можно открыть `07 Показатели/Проверка показателей.md` и посмотреть, совпадают ли человек, дата, показатель, значение и единицы.</li>
        <li>После подтверждения я перенесу одобренное в `metrics.json`, проверю дубли, соберу сайт и опубликую.</li>
      </ol>
    </article>

    <article class="card prose">
      <h2>Что проверять</h2>
      <ul>
        <li>Значение и единицы должны быть такими же, как в исходнике или в точной md-записи события.</li>
        <li>Лейкоциты должны быть разделены по контексту: кровь, моча или мазок.</li>
        <li>Одинаковый результат в разные даты не считается дублем, это нормальная динамика.</li>
        <li>Точный дубль одного и того же события и показателя пропускается автоматически.</li>
        <li>JSON руками обычно не редактируем: он нужен сайту и агенту.</li>
      </ul>
    </article>

    <article class="card">
      <h2>Проблемы данных</h2>
      {issues.length ? (
        <ul class="issue-list">
          {issues.map((issue) => <li><strong>{issue.severity}</strong> {issue.message}</li>)}
        </ul>
      ) : (
        <p class="empty">Существенных проблем данных нет.</p>
      )}
    </article>
  </section>
</AppLayout>
